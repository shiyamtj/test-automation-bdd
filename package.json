{
  "name": "test-automation-bdd",
  "version": "1.0.0",
  "description": "BDD test automation project using CucumberJS, Playwright, and TypeScript",
  "main": "index.js",
  "scripts": {
    "preinstall": "node scripts/check-preinstall.js",
    "postinstall": "npx playwright install",
    "uninstall-browsers": "npx playwright uninstall --all",
    "clean": "rm -rf test-results && rm -rf reports",
    "clean:playwright-cache:windows": "rm -rf %USERPROFILE%\\AppData\\Local\\ms-playwright",
    "pretest":"yarn clean",
    "test": "cucumber-js --format progress-bar --format html:test-results/cucumber-report.html --format json:test-results/cucumber-report.json",
    "test:smoke": "cucumber-js --tags @smoke",
    "test:regression": "cucumber-js --tags @regression",
    "pretest:concurrent": "yarn clean",
    "test:concurrent": "ts-node run-tests.ts",
    "report": "node generate-report.js"
  },
  "keywords": [
    "cucumber",
    "playwright",
    "typescript",
    "bdd",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "yarn": ">=1.22.0",
    "npm": "please-use-yarn"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^9.5.1",
    "@playwright/test": "^1.40.1",
    "@types/node": "^20.10.5",
    "playwright": "^1.40.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "multiple-cucumber-html-reporter": "^3.10.0"
  },
  "dependencies": {
    "cross-env": "^10.1.0",
    "dotenv": "^16.3.1"
  }
}

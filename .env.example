# Copy this file to .env and update only the values you want to override
# All values have sensible defaults defined in tests/config/constants.ts

# Application URL (optional - defaults to https://www.saucedemo.com)
# BASE_URL=https://www.saucedemo.com

# Browser settings (optional - uses defaults from constants.ts)
# BROWSER=chromium
# HEADLESS=true
# SLOW_MO=0

# Viewport settings (optional - defaults to 1280x720)
# VIEWPORT_WIDTH=1280
# VIEWPORT_HEIGHT=720

# Timeouts in milliseconds (optional - uses defaults from constants.ts)
# NAVIGATION_TIMEOUT=30000
# ACTION_TIMEOUT=10000

# Playwright Tracing (optional - defaults to false)
# Set to 'true' to enable Playwright tracing for debugging
# ENABLE_TRACING=false

# Test user credentials (optional - uses defaults from constants.ts)
# VALID_USERNAME=standard_user
# VALID_PASSWORD=secret_sauce
# INVALID_USERNAME=invalid_user
# INVALID_PASSWORD=wrong_password

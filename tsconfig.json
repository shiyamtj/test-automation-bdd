{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noImplicitAny": true,
    "moduleResolution": "node"
  },
  "ts-node": {
    "transpileOnly": false,
    "compilerOptions": {
      "module": "commonjs"
    }
  },
  "include": [
    "tests/**/*",
    ".github/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
